FROM ollama/ollama
RUN apt-get update && apt-get install -y \
    curl \
    python3 \
    python3-pip \
    && pip3 install huggingface_hub --break-system-packages \
    && rm -rf /var/lib/apt/lists/*

COPY aiAnalyst/Modelfile.short /app/Modelfile.quantv22


COPY ollama-init.sh /app/ollama-init.sh

RUN chmod +x /app/ollama-init.sh

ENTRYPOINT ["/app/ollama-init.sh"]
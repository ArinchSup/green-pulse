FROM python:3.11-slim

WORKDIR /app

COPY aiAnalyst/requirements.txt /app/.
RUN pip install --no-cache-dir -r requirements.txt

COPY aiFastAPI.py .
COPY aimain.py .
COPY aiCheckPrediction.py .
COPY aiAnalyst/ ./aiAnalyst/

EXPOSE 8001

CMD ["uvicorn", "aiFastAPI:app", "--host", "0.0.0.0", "--port", "8001"]